@{
    ViewData["Title"] = "Test rezultate pe raioane";
}

<div class="mb-8">
    <h3 class="text-3xl font-bold text-gray-800 mb-2">Rezultate pe Raioane</h3>
    <p class="text-gray-600">Click pe un raion pentru a vedea top 7 partide (după numărul de voturi).</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Harta Moldovei -->
    <div class="space-y-4">
        <div id="chartdiv" style="width: 100%; height: 600px;"></div>
    </div>

    <!-- Panou rezultate -->
    <div id="results-panel" class="bg-white rounded-lg shadow-lg p-6 border border-gray-200">
        <div class="flex items-center gap-3 mb-4 pb-4 border-b border-gray-200">
            <svg class="w-7 h-7 text-blue-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
            <div>
                <h4 id="region-name" class="text-2xl font-bold text-gray-800">Alege un raion</h4>
                <p class="text-sm text-gray-500">Vor fi afișate primele 7 partide după numărul de voturi.</p>
            </div>
        </div>

        <div id="top-parties-list" class="space-y-2">
            <p class="text-gray-500 text-sm text-center">Selectează un raion de pe hartă pentru a vedea rezultatele.</p>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.amcharts.com/lib/5/index.js"></script>
    <script src="https://cdn.amcharts.com/lib/5/map.js"></script>
    <script src="https://cdn.amcharts.com/lib/5/themes/Animated.js"></script>
    <script src="https://cdn.amcharts.com/lib/5/geodata/moldovaHigh.js"></script>

    <script>
        window.mapData = [];
        fetch('/Statistics/GetMapData')
            .then(function (response) { return response.json(); })
            .then(function (data) {
                window.mapData = data;
                window.dispatchEvent(new Event('resultsMapDataLoaded'));
            })
            .catch(function (e) {
                console.error('Error loading map data for results:', e);
                window.mapData = [];
            });
    </script>

    <script src="~/js/resultsMap.js"></script>
}
